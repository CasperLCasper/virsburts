/*
  Content-Security-Policy: default-src 'none'; script-src 'self'; connect-src 'self' https: wss:; img-src 'self' data: https: blob:; style-src 'self' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; media-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; form-action 'none'; base-uri 'none';
